generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////
// 👤 USERS
///////////////////////
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())

  orders  Order[]
  reviews Review[]
}

///////////////////////
// 📂 CATEGORIES
///////////////////////
model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  products Product[]
}

///////////////////////
// 🛍️ PRODUCTS
///////////////////////
model Product {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  price       Float
  discount    Float?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())

  offerTag            String?
  tripleTreatAlert    String?
  countdownExpiry     DateTime?
  specifications      Json?
  deliveryEstimate    String?
  badges              String[]
  imageUrls           String[]

  relatedProductIds   String[] @default([])
  categories Category[]

  images   ProductImage[]
  details  ProductDetail[]
  reviews  Review[]
  orderItems OrderItem[]
}

///////////////////////
// 🖼️ PRODUCT IMAGES
///////////////////////
model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

///////////////////////
// 📄 PRODUCT DETAILS
///////////////////////
model ProductDetail {
  id        String @id @default(cuid())
  label     String
  value     String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

///////////////////////
// ⭐ REVIEWS
///////////////////////
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

///////////////////////
// 🛒 ORDERS
///////////////////////
model Order {
  id        String   @id @default(cuid())
  total     Float
  status    String   @default("pending")
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  items     OrderItem[]
  address   Address?

  paymentId         String?  // Razorpay Payment ID
  shiprocketOrderId String?  // Shiprocket Order ID
  shipmentStatus    String?  // Shiprocket Status

  affiliateId       String?
  affiliate         Affiliate? @relation(fields: [affiliateId], references: [id])
}

///////////////////////
// 📦 ORDER ITEMS
///////////////////////
model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Float

  orderId   String
  productId String

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

///////////////////////
// 🤝 AFFILIATES
///////////////////////
model Affiliate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String?  // For dashboard login
  phone          String?
  youtubeUrl     String?
  instagramUrl   String?
  code           String?  @unique // Nullable for pending requests
  commissionRate Float    @default(10.0)
  totalSales     Float    @default(0)
  totalEarnings  Float    @default(0)
  payoutInfo     String?  @default("")
  status         String   @default("pending") // pending, approved, rejected, inactive
  
  orders         Order[]  // Orders referred by this affiliate
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

///////////////////////
// 🏠 ADDRESS
///////////////////////
model Address {
  id        String @id @default(cuid())
  fullName  String
  phone     String
  city      String
  state     String
  pincode   String
  address   String

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])
}

///////////////////////
// 🎁 OFFERS / COUPONS
///////////////////////
model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique // The coupon code entered by the user
  discountType    String   // 'PERCENTAGE', 'FIXED_AMOUNT', 'BOGO', 'FREE_SHIPPING', 'BEHAVIORAL', 'BANK_OFFER'
  
  // Values
  discountValue   Float?   // Amount or Percentage. (e.g. 20 for 20%, or 500 for ₹500)
  description     String?  // e.g. "Flat 20% Off", "Buy 2 Get 1 Free"
  
  // Constraints
  minPurchase     Float?   // e.g. "₹300 off on orders above ₹1500"
  maxDiscount     Float?   // e.g. "Upto ₹1000 Off"
  
  // BOGO / Bundle
  buyQuantity     Int?     // e.g. Buy 2
  getQuantity     Int?     // e.g. Get 1
  isBundle        Boolean  @default(false)

  // Advanced Routing
  targetCustomer  String?  @default("ALL") // 'ALL', 'NEW_USER', 'ABANDONED_CART'
  bankName        String?  // e.g. 'HDFC', 'SBI'

  // Limits
  expiresAt       DateTime?
  usageLimit      Int?
  usedCount       Int      @default(0)
  
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

///////////////////////
// 📑 STATIC CONTENT
///////////////////////
// 📑 CUSTOM PAGES (Builder)
///////////////////////
model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections  PageSection[]
}

model PageSection {
  id        String   @id @default(cuid())
  type      String   // 'hero', 'about', 'products', 'text', 'instagram', 'features'
  content   Json     // Stores all section-specific data (title, images, etc.)
  order     Int      @default(0)
  active    Boolean  @default(true)

  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

// Keep Content for backward compatibility or simple one-off blocks
model Content {
  id    String @id @default(cuid())
  title String
  body  String
}

///////////////////////
// ⚙️ STORE SETTINGS
///////////////////////
model StoreSettings {
  id               String @id @default("global") // Keep a single row
  razorpayKeyId    String?
  razorpaySecret   String?
  shiprocketEmail  String?
  shiprocketPassword String?
}

///////////////////////
// 🛒 ABANDONED CHECKOUTS
///////////////////////
model AbandonedCheckout {
  id              String   @id @default(cuid())
  email           String?
  phone           String?
  firstName       String?
  lastName        String?
  address         String?
  apartment       String?
  city            String?
  state           String?
  pincode         String?
  
  cartItems       Json     // Stores items as {id, title, price, quantity, image}[]
  total           Float
  discountAmount  Float    @default(0)
  couponCode      String?
  
  recoveryToken   String   @unique @default(cuid())
  lastStep        String   @default("contact") // 'contact', 'delivery', 'payment'
  
  remindersSent   Int      @default(0)
  lastReminderSent DateTime?
  
  recovered       Boolean  @default(false)
  recoveredAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}