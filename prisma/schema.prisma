generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ////////////////////
/// ////////////////////
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())
  orders    Order[]
  reviews   Review[]
}

/// ////////////////////
/// ////////////////////
model Category {
  id            String     @id @default(cuid())
  name          String
  slug          String     @unique
  createdAt     DateTime   @default(now())
  icon          String?
  parentId      String?
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subcategories Category[] @relation("SubCategories")
  products      Product[]  @relation("CategoryToProduct")
}

/// ////////////////////
/// ////////////////////
model Product {
  id                String          @id @default(cuid())
  title             String
  slug              String          @unique
  price             Float
  createdAt         DateTime        @default(now())
  description       String
  discount          Float?
  stock             Int             @default(0)
  badges            String[]
  countdownExpiry   DateTime?
  deliveryEstimate  String?
  imageUrls         String[]
  offerTag          String?
  specifications    Json?
  tripleTreatAlert  String?
  relatedProductIds String[]        @default([])
  orderItems        OrderItem[]
  details           ProductDetail[]
  images            ProductImage[]
  reviews           Review[]
  categories        Category[]      @relation("CategoryToProduct")
}

/// ////////////////////
/// ////////////////////
model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// ////////////////////
/// ////////////////////
model ProductDetail {
  id        String  @id @default(cuid())
  label     String
  value     String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// ////////////////////
/// ////////////////////
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  userId    String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

/// ////////////////////
/// ////////////////////
model Order {
  id                String      @id @default(cuid())
  total             Float
  status            String      @default("pending")
  createdAt         DateTime    @default(now())
  userId            String
  paymentId         String?
  shipmentStatus    String?
  shiprocketOrderId String?
  affiliateId       String?
  address           Address?
  affiliate         Affiliate?  @relation(fields: [affiliateId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]
}

/// ////////////////////
/// ////////////////////
model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// ////////////////////
/// ////////////////////
model Affiliate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  code           String?  @unique
  commissionRate Float    @default(10.0)
  totalSales     Float    @default(0)
  totalEarnings  Float    @default(0)
  payoutInfo     String?  @default("")
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  instagramUrl   String?
  phone          String?
  youtubeUrl     String?
  password       String?
  orders         Order[]
}

/// ////////////////////
/// ////////////////////
model Address {
  id       String @id @default(cuid())
  fullName String
  phone    String
  city     String
  state    String
  pincode  String
  address  String
  orderId  String @unique
  order    Order  @relation(fields: [orderId], references: [id])
}

/// ////////////////////
/// ////////////////////
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  bankName       String?
  buyQuantity    Int?
  description    String?
  discountType   String
  discountValue  Float?
  expiresAt      DateTime?
  getQuantity    Int?
  isBundle       Boolean   @default(false)
  maxDiscount    Float?
  minPurchase    Float?
  targetCustomer String?   @default("ALL")
  updatedAt      DateTime  @updatedAt
  usageLimit     Int?
  usedCount      Int       @default(0)
  productIds     String[]  @default([])
  categoryIds    String[]  @default([])
}

/// ////////////////////
/// ////////////////////
/// ////////////////////
model Page {
  id        String        @id @default(cuid())
  title     String
  slug      String        @unique
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sections  PageSection[]
}

model PageSection {
  id      String  @id @default(cuid())
  type    String
  content Json
  order   Int     @default(0)
  active  Boolean @default(true)
  pageId  String
  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Content {
  id    String @id @default(cuid())
  title String
  body  String
}

/// ////////////////////
/// ////////////////////
model StoreSettings {
  id                 String  @id @default("global")
  razorpayKeyId      String?
  razorpaySecret     String?
  shiprocketEmail    String?
  shiprocketPassword String?
  supportEmail       String?
}

/// ////////////////////
/// ////////////////////
model AbandonedCheckout {
  id               String    @id @default(cuid())
  email            String?
  phone            String?
  firstName        String?
  lastName         String?
  address          String?
  apartment        String?
  city             String?
  state            String?
  pincode          String?
  cartItems        Json
  total            Float
  discountAmount   Float     @default(0)
  couponCode       String?
  recoveryToken    String    @unique @default(cuid())
  lastStep         String    @default("contact")
  remindersSent    Int       @default(0)
  lastReminderSent DateTime?
  recovered        Boolean   @default(false)
  recoveredAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
